{
  "name": "trapo-web",
  "license": "MIT",
  "author": "Agus Works",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint",
    "generate-api": "bun run generate-openapi && orval --config orval.config.ts",
    "generate-api:ci": "bun run generate-openapi:ci && orval --config orval.config.ts",
    "generate-openapi": "uv run --project .. python -m trapo.server.openapi --output openapi/trapo.openapi.json",
    "generate-openapi:ci": "uv run --project .. --no-sync python -m trapo.server.openapi --output openapi/trapo.openapi.json",
    "generate-routes": "tsr generate",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1",
    "build-storybook": "storybook build",
    "build": "bun run generate-api && bun run generate-routes && tsc -b && vite build",
    "build:ci": "bun run generate-api:ci && bun run generate-routes && tsc -b && vite build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --unsafe .",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "bun run generate-api && bun run generate-routes && tsc -b --pretty false",
    "typecheck:ci": "bun run generate-api:ci && bun run generate-routes && tsc -b --pretty false"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "1.2.9",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.2.0",
    "react-resizable-panels": "^3.0.6",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "orval": "^8.16.0",
    "storybook": "^10.4.5",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
